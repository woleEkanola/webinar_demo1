generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Question {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  answers   Answer[]
}

model Answer {
  id         Int      @id @default(autoincrement())
  questionId Int
  text       String
  votes      Int      @default(0)
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}